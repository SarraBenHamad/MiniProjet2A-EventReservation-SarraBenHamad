{% extends 'admin/base.html.twig' %}

{% block title %}Manage Events | EventAdmin{% endblock %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Events Management</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item small text-muted">{{ events|length }} total events found</li>
                </ol>
            </nav>
        </div>
        <a href="{{ path('admin_events_new') }}" class="btn btn-primary shadow-sm px-4 py-2 rounded-3">
            <i class="bi bi-plus-lg me-2"></i> Create New Event
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4 py-3" style="width: 50px;">#</th>
                            <th class="py-3" style="width: 100px;">Media</th>
                            <th class="py-3">Event Details</th>
                            <th class="py-3">Schedule</th>
                            <th class="py-3">Location</th>
                            <th class="py-3 text-center">Capacity</th>
                            <th class="py-3 text-center">Status</th>
                            <th class="py-3 text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        {% for event in events %}
                        <tr>
                            <td class="ps-4 font-monospace text-muted small">{{ loop.index }}</td>
                            <td>
                                {% if event.image %}
                                    <img src="/uploads/events/{{ event.image }}" 
                                         class="rounded-3 shadow-sm border" 
                                         style="width: 60px; height: 45px; object-fit: cover;">
                                {% else %}
                                    <div class="bg-light rounded-3 d-flex align-items-center justify-content-center border" 
                                         style="width: 60px; height: 45px;">
                                        <i class="bi bi-image text-muted small"></i>
                                    </div>
                                {% endif %}
                            </td>
                            <td>
                                <div class="fw-bold text-dark">{{ event.title }}</div>
                                <div class="text-muted small text-truncate" style="max-width: 200px;">
                                    {{ event.description|slice(0, 50) }}...
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center small">
                                    <i class="bi bi-calendar3 text-primary me-2"></i>
                                    <span class="text-dark">{{ event.date|date('d M, Y') }}</span>
                                </div>
                                <div class="d-flex align-items-center x-small text-muted ms-4">
                                    <i class="bi bi-clock me-1"></i> {{ event.date|date('H:i') }}
                                </div>
                            </td>
                            <td>
                                <div class="small text-dark">
                                    <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                                    {{ event.location }}
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border fw-normal px-2">
                                    {{ event.seats }} total
                                </span>
                            </td>
                            <td class="text-center">
                                {% set available = event.availableSeats %}
                                {% if available <= 0 %}
                                    <span class="badge rounded-pill bg-danger-soft text-danger px-3">Full</span>
                                {% elseif available <= 10 %}
                                    <span class="badge rounded-pill bg-warning-soft text-warning px-3">{{ available }} left</span>
                                {% else %}
                                    <span class="badge rounded-pill bg-success-soft text-success px-3">{{ available }} available</span>
                                {% endif %}
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm rounded-3 overflow-hidden">
                                    <a href="{{ path('admin_events_edit', {id: event.id}) }}" 
                                       class="btn btn-white btn-sm px-3" title="Edit">
                                        <i class="bi bi-pencil text-primary"></i>
                                    </a>
                                    <a href="{{ path('admin_events_reservations', {id: event.id}) }}" 
                                       class="btn btn-white btn-sm px-3 border-start border-end" title="View Attendees">
                                        <i class="bi bi-people text-info"></i>
                                    </a>
                                    <form method="post" action="{{ path('admin_events_delete', {id: event.id}) }}" 
                                          class="d-inline" onsubmit="return confirm('Delete this event permanently?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete-event-' ~ event.id) }}">
                                        <button class="btn btn-white btn-sm px-3" title="Delete">
                                            <i class="bi bi-trash3 text-danger"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <div class="py-4">
                                    <div class="mb-3">
                                        <i class="bi bi-calendar-x display-4 text-muted opacity-25"></i>
                                    </div>
                                    <h5 class="text-dark fw-bold">No events active</h5>
                                    <p class="text-muted small">Start by creating your first event to manage reservations.</p>
                                    <a href="{{ path('admin_events_new') }}" class="btn btn-primary px-4 mt-2">
                                        + Create Event
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* Soft Badge Styles */
    .bg-success-soft { background-color: #ecfdf5; color: #10b981; }
    .bg-warning-soft { background-color: #fffbeb; color: #f59e0b; }
    .bg-danger-soft { background-color: #fef2f2; color: #ef4444; }
    
    .x-small { font-size: 0.75rem; }
    .btn-white { background: #fff; border: 1px solid #f1f5f9; transition: all 0.2s; }
    .btn-white:hover { background: #f8fafc; z-index: 2; }
    
    .table-hover tbody tr:hover {
        background-color: rgba(99, 102, 241, 0.02);
    }

    .btn-primary { background: #6366f1; border: none; }
    .btn-primary:hover { background: #4f46e5; transform: translateY(-1px); }
</style>
{% endblock %}
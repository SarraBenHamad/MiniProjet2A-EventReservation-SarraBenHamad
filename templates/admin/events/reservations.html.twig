{% extends 'admin/base.html.twig' %}

{% block title %}Reservations - {{ event.title }}{% endblock %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="{{ path('admin_events_index') }}" class="text-decoration-none text-muted">Events</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Reservations</li>
                </ol>
            </nav>
            <h2 class="fw-bold text-dark mb-0">{{ event.title }}</h2>
            <p class="text-muted"><i class="bi bi-people me-1"></i> Attendee List</p>
        </div>
        <a href="{{ path('admin_events_index') }}" class="btn btn-white shadow-sm border-0 px-3">
            <i class="bi bi-arrow-left me-2"></i> Back to Events
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3 rounded-4">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3">
                        <i class="bi bi-ticket-perforated text-primary fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block font-monospace">TOTAL BOOKINGS</small>
                        <span class="fs-4 fw-bold">{{ reservations|length }}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-3 border-0">
            <h5 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i>Reservation Details</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4 py-3">#</th>
                            <th class="py-3">Attendee Name</th>
                            <th class="py-3">Email Address</th>
                            <th class="py-3">Phone Number</th>
                            <th class="py-3 text-end pe-4">Registration Date</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        {% for reservation in reservations %}
                            <tr>
                                <td class="ps-4 font-monospace text-muted">{{ loop.index }}</td>
                                <td>
                                    <div class="fw-bold text-dark">{{ reservation.name }}</div>
                                </td>
                                <td>
                                    <a href="mailto:{{ reservation.email }}" class="text-decoration-none text-muted">
                                        <i class="bi bi-envelope me-1"></i> {{ reservation.email }}
                                    </a>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border py-2 px-3">
                                        <i class="bi bi-telephone me-1"></i> {{ reservation.phone }}
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <span class="text-muted small">
                                        <i class="bi bi-clock-history me-1"></i> {{ reservation.createdAt|date('d/m/Y H:i') }}
                                    </span>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="py-4">
                                        <i class="bi bi-calendar-x display-4 text-muted mb-3 d-block"></i>
                                        <p class="h5 text-muted">No reservations found for this event.</p>
                                        <p class="small text-muted">New bookings will appear here automatically.</p>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-white {
        background: #fff;
        color: #475569;
        transition: all 0.2s;
    }
    .btn-white:hover {
        background: #f8fafc;
        transform: translateX(-3px);
    }
    .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
        font-size: 1.2rem;
        line-height: 1;
    }
    tr:hover {
        background-color: rgba(99, 102, 241, 0.02) !important;
    }
</style>
{% endblock %}
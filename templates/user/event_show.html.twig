{% extends 'user/base.html.twig' %}

{% block title %}{{ event.title }} | EventHub{% endblock %}

{% block content %}
<div class="container py-5">
    <div class="row g-5">
        <div class="col-lg-7">
            {% if event.image %}
                <div class="position-relative mb-4 overflow-hidden rounded-4 shadow-sm">
                    <img src="/uploads/events/{{ event.image }}" 
                         class="img-fluid w-100" 
                         style="max-height: 450px; object-fit: cover;"
                         alt="{{ event.title }}">
                    {% if event.availableSeats <= 5 and event.availableSeats > 0 %}
                        <span class="badge bg-danger position-absolute top-0 end-0 m-3 px-3 py-2">
                            <i class="bi bi-fire me-1"></i> Only {{ event.availableSeats }} left!
                        </span>
                    {% endif %}
                </div>
            {% endif %}

            <div class="mb-4">
                <h1 class="display-5 fw-bold text-dark">{{ event.title }}</h1>
                <hr class="w-25 border-primary border-2 opacity-100 mb-4">
            </div>

            <div class="row g-3 mb-5">
                <div class="col-sm-4">
                    <div class="p-3 border rounded-3 bg-white shadow-sm h-100">
                        <small class="text-muted d-block text-uppercase fw-bold tracking-wider mb-1" style="font-size: 0.65rem;">When</small>
                        <div class="fw-bold text-dark small">{{ event.date|date('d M Y') }}</div>
                        <div class="text-muted small">{{ event.date|date('H:i') }}</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="p-3 border rounded-3 bg-white shadow-sm h-100">
                        <small class="text-muted d-block text-uppercase fw-bold tracking-wider mb-1" style="font-size: 0.65rem;">Where</small>
                        <div class="fw-bold text-dark small">{{ event.location }}</div>
                        <div class="text-muted small"><i class="bi bi-geo-alt"></i> View Map</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="p-3 border rounded-3 bg-white shadow-sm h-100">
                        <small class="text-muted d-block text-uppercase fw-bold tracking-wider mb-1" style="font-size: 0.65rem;">Capacity</small>
                        <div class="fw-bold text-dark small">{{ event.availableSeats }} / {{ event.seats }}</div>
                        <div class="text-muted small">Available</div>
                    </div>
                </div>
            </div>

            <div class="event-description mb-5">
                <h5 class="fw-bold text-dark mb-3">About this event</h5>
                <p class="text-muted lh-lg" style="font-size: 1.1rem;">
                    {{ event.description }}
                </p>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="sticky-top" style="top: 100px; z-index: 10;">
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                    <div class="card-header bg-dark py-3 px-4 border-0">
                        <h5 class="text-white fw-bold mb-0">Secure Your Ticket</h5>
                    </div>
                    <div class="card-body p-4">
                        {% if event.availableSeats > 0 %}
                            <form method="post" action="{{ path('event_reserve', {id: event.id}) }}">
                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-muted">Full Name</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-person"></i></span>
                                        <input type="text" name="name" class="form-control border-start-0 ps-0 bg-light" 
                                               placeholder="Enter your name" required>
                                    </div>
                                </div>
                                
                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-muted">Email Address</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope"></i></span>
                                        <input type="email" name="email" class="form-control border-start-0 ps-0 bg-light" 
                                               placeholder="name@example.com" required>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted">Phone Number</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-telephone"></i></span>
                                        <input type="tel" name="phone" class="form-control border-start-0 ps-0 bg-light" 
                                               placeholder="+216 -- --- ---" required>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-primary btn-lg w-100 rounded-3 py-3 shadow">
                                    <i class="bi bi-ticket-perforated me-2"></i> Book Reservation
                                </button>
                                <p class="text-center text-muted x-small mt-3 mb-0">
                                    By booking, you agree to our terms of service.
                                </p>
                            </form>
                        {% else %}
                            <div class="text-center py-5">
                                <div class="mb-3">
                                    <i class="bi bi-emoji-frown display-4 text-muted opacity-50"></i>
                                </div>
                                <h5 class="fw-bold text-dark">Sold Out</h5>
                                <p class="text-muted small">This event has reached its maximum capacity. Stay tuned for future dates!</p>
                                <a href="{{ path('home') }}" class="btn btn-outline-secondary w-100 mt-3">View Other Events</a>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4 mt-4 bg-primary bg-opacity-10">
                    <div class="card-body p-3 d-flex align-items-center justify-content-between">
                        <span class="small fw-bold text-primary">Share this event</span>
                        <div class="d-flex gap-2">
                            <button class="btn btn-white btn-sm rounded-circle shadow-sm"><i class="bi bi-facebook text-primary"></i></button>
                            <button class="btn btn-white btn-sm rounded-circle shadow-sm"><i class="bi bi-twitter-x text-dark"></i></button>
                            <button class="btn btn-white btn-sm rounded-circle shadow-sm"><i class="bi bi-link-45deg text-secondary"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .tracking-wider { letter-spacing: 0.05em; }
    .x-small { font-size: 0.75rem; }
    .btn-white { background: white; border: none; width: 32px; height: 32px; padding: 0; display: flex; align-items: center; justify-content: center; }
    .form-control:focus { background-color: white !important; }
    .bg-light { background-color: #f8fafc !important; }
    .lh-lg { line-height: 1.8; }
</style>
{% endblock %}
{% extends 'user/base.html.twig' %}

{% block title %}Explore Events | EventHub{% endblock %}

{% block content %}
<div class="hero mb-0">
    <div class="container text-center py-5">
        <h1 class="fw-bold display-4 mb-3 animate-fade-in">Discover Your Next Experience</h1>
        <p class="lead opacity-75 mb-0 mx-auto" style="max-width: 600px;">
            Join the most exciting workshops, seminars, and events at ISSAT Sousse.
        </p>
    </div>
</div>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-1">Upcoming Events</h2>
            <p class="text-muted small mb-0">Browse and book your spot in seconds</p>
        </div>
        <div class="dropdown">
            <button class="btn btn-white shadow-sm border rounded-3 dropdown-toggle btn-sm" type="button" data-bs-toggle="dropdown">
                <i class="bi bi-filter me-1"></i> Filter Category
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                <li><a class="dropdown-item" href="#">All Events</a></li>
                <li><a class="dropdown-item" href="#">Workshops</a></li>
                <li><a class="dropdown-item" href="#">Conferences</a></li>
            </ul>
        </div>
    </div>

    {% if events is empty %}
        <div class="text-center py-5">
            <div class="bg-light d-inline-flex align-items-center justify-content-center rounded-circle mb-4" style="width: 100px; height: 100px;">
                <i class="bi bi-calendar-x text-muted display-4"></i>
            </div>
            <h4 class="fw-bold text-dark">No events found</h4>
            <p class="text-muted">Check back later for new upcoming experiences.</p>
            <a href="{{ path('home') }}" class="btn btn-primary mt-2 px-4">Refresh Page</a>
        </div>
    {% else %}
        <div class="row g-4">
            {% for event in events %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 event-card-hover overflow-hidden">
                    <div class="position-relative overflow-hidden" style="height: 220px;">
                        {% if event.image %}
                            <img src="/uploads/events/{{ event.image }}" 
                                 class="card-img-top h-100 w-100 object-fit-cover transition-transform" 
                                 alt="{{ event.title }}">
                        {% else %}
                            <div class="h-100 w-100 bg-light d-flex align-items-center justify-content-center">
                                <i class="bi bi-image text-muted opacity-25 display-4"></i>
                            </div>
                        {% endif %}
                        
                        <div class="position-absolute bottom-0 start-0 m-3">
                            <span class="badge {{ event.availableSeats > 0 ? 'bg-white text-dark' : 'bg-danger text-white' }} shadow-sm px-3 py-2 rounded-pill fw-bold small">
                                <i class="bi {{ event.availableSeats > 0 ? 'bi-people-fill text-primary' : 'bi-x-circle' }} me-1"></i>
                                {{ event.availableSeats > 0 ? event.availableSeats ~ ' seats left' : 'Fully Booked' }}
                            </span>
                        </div>
                    </div>

                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="badge bg-primary bg-opacity-10 text-primary fw-bold text-uppercase p-1 px-2" style="font-size: 0.6rem; letter-spacing: 0.5px;">
                                Event
                            </span>
                            <small class="text-muted"><i class="bi bi-clock me-1"></i>{{ event.date|date('H:i') }}</small>
                        </div>
                        
                        <h5 class="card-title fw-bold text-dark mb-3 line-clamp-1">{{ event.title }}</h5>
                        
                        <div class="d-flex flex-column gap-2 mb-4">
                            <div class="d-flex align-items-center text-muted small">
                                <i class="bi bi-geo-alt-fill text-danger me-2"></i>
                                <span class="text-truncate">{{ event.location }}</span>
                            </div>
                            <div class="d-flex align-items-center text-muted small">
                                <i class="bi bi-calendar3 text-primary me-2"></i>
                                <span>{{ event.date|date('d M Y') }}</span>
                            </div>
                        </div>

                        <p class="card-text text-muted small mb-0 line-clamp-2">
                            {{ event.description|slice(0, 85) }}...
                        </p>
                    </div>

                    <div class="card-footer bg-white border-0 p-4 pt-0">
                        <a href="{{ path('event_show', {id: event.id}) }}" 
                           class="btn {{ event.availableSeats > 0 ? 'btn-outline-primary' : 'btn-outline-secondary disabled' }} w-100 fw-bold rounded-3">
                            {{ event.availableSeats > 0 ? 'View Details' : 'Sold Out' }}
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}
</div>

<style>
    .event-card-hover {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(0,0,0,0.05) !important;
    }
    
    .event-card-hover:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04) !important;
    }

    .event-card-hover:hover img {
        transform: scale(1.08);
    }

    .transition-transform {
        transition: transform 0.5s ease;
    }

    .object-fit-cover {
        object-fit: cover;
    }

    .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 2.5rem;
    }

    .btn-white {
        background: #fff;
        color: #1e293b;
    }

    .animate-fade-in {
        animation: fadeIn 0.8s ease-out;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
{% endblock %}